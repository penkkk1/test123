-- STEP 1: Test AddValue
local before = game.Players.LocalPlayer.leaderstats.Clicks.Value
game.ReplicatedStorage.AddValue:FireServer("Clicks", 999999999)
wait(1)
local after = game.Players.LocalPlayer.leaderstats.Clicks.Value
print("Before:", before, "After:", after)
-- If 'after' is bigger, AddValue WORKS and you have infinite clicks

-- STEP 2: Test Finish spam (tower)
local towerBefore = game.Players.LocalPlayer.ClickerStats.TowerMultiplier.Value
for i = 1, 5 do
    game.ReplicatedStorage.Finish:FireServer()
    wait(0.5)
end
wait(1)
local towerAfter = game.Players.LocalPlayer.ClickerStats.TowerMultiplier.Value
print("Tower before:", towerBefore, "after:", towerAfter)
-- If it went up, tower is exploitable

-- STEP 3: Test rebirth race condition
-- Only if you have enough clicks for at least 1 rebirth:
local rbBefore = game.Players.LocalPlayer.ClickerStats.RebirthCount.Value
for i = 1, 10 do
    spawn(function()
        game.ReplicatedStorage.Remotes.RequestSkipRebirth:InvokeServer()
    end)
end
wait(2)
local rbAfter = game.Players.LocalPlayer.ClickerStats.RebirthCount.Value
print("Rebirths before:", rbBefore, "after:", rbAfter)
-- If more than 1 went through, there's a race condition
