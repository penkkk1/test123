-- =====================================================
--  FPS BOOST (v6: mai agresiv, mai eficient)
-- =====================================================
local _fpsApplied = false

local function enableFpsBoost()
    if _fpsApplied then return end
    _fpsApplied = true

    -- Lighting cleanup
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        for _, c in ipairs(Lighting:GetChildren()) do
            if c:IsA("PostEffect") or c:IsA("Atmosphere") or c:IsA("Sky") then
                c:Destroy()
            end
        end
    end)

    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- Batch cleanup — o singura iteratie, nu nested pcalls
    pcall(function()
        for _, d in ipairs(workspace:GetDescendants()) do
            local s, _ = pcall(function()
                local cn = d.ClassName
                -- VFX off
                if cn == "ParticleEmitter" or cn == "Trail" or cn == "Beam"
                    or cn == "Smoke" or cn == "Fire" or cn == "Sparkles" then
                    d.Enabled = false
                -- Lights off
                elseif cn == "PointLight" or cn == "SpotLight" or cn == "SurfaceLight" then
                    d.Enabled = false
                -- Textures transparent
                elseif cn == "Decal" or cn == "Texture" then
                    d.Transparency = 1
                -- Parts simplified
                elseif d:IsA("BasePart") then
                    d.Material = Enum.Material.SmoothPlastic
                    d.CastShadow = false
                    -- Remove mesh textures (reduces draw calls significantly)
                    if d:IsA("MeshPart") then
                        d.TextureID = ""
                    end
                end
            end)
        end
    end)

    -- Terrain
    pcall(function()
        local t = workspace.Terrain
        t.WaterWaveSize = 0
        t.WaterWaveSpeed = 0
        t.WaterReflectance = 0
        t.WaterTransparency = 0
        t.Decoration = false
    end)

    -- Other players invisible + nametags off
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                for _, part in ipairs(p.Character:GetDescendants()) do
                    pcall(function()
                        if part:IsA("BasePart") or part:IsA("Decal")
                            or part:IsA("MeshPart") then
                            part.Transparency = 1
                        end
                        if part:IsA("Humanoid") then
                            part.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                        end
                    end)
                end
            end
        end
    end)

    print("[FPS] Boost ON")
end

local function disableFpsBoost()
    _fpsApplied = false
    pcall(function()
        Lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    end)
    print("[FPS] Boost OFF (rejoin pt full restore)")
end

