-- [DELTA FIX] Variantă care ocolește problema loadstring
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

print("[Delta] Start...")

-- TESTĂM ce funcționează pe acest executor
local hasLoadstring = pcall(function() loadstring("return true")() end)
local hasHttpGet = pcall(function() game:HttpGet("https://httpbin.org/get", true) end)

print("[Delta] loadstring: " .. tostring(hasLoadstring))
print("[Delta] HttpGet: " .. tostring(hasHttpGet))

-- Încercăm TOATE metodele posibile de a încărca SSI
local synsaveinstance = nil

-- Metoda 1: saveinstance nativ (unele versiuni de Delta îl au built-in)
if saveinstance then
    synsaveinstance = saveinstance
    print("[Delta] Folosim saveinstance nativ (built-in)!")
elseif syn and syn.saveinstance then
    synsaveinstance = syn.saveinstance
    print("[Delta] Folosim syn.saveinstance!")
elseif KRNL_LOADED and saveinstance then
    synsaveinstance = saveinstance
    print("[Delta] Folosim KRNL saveinstance!")
end

-- Metoda 2: loadstring + HttpGet
if not synsaveinstance and hasLoadstring and hasHttpGet then
    local urls = {
        "https://raw.githubusercontent.com/luau/SynSaveInstance/main/saveinstance.luau",
        "https://raw.githubusercontent.com/luau/UniversalSynSaveInstance/main/saveinstance.luau",
    }
    for _, url in ipairs(urls) do
        local ok, result = pcall(function()
            local code = game:HttpGet(url, true)
            if code and #code > 100 then
                local fn = loadstring(code)
                if fn then return fn() end
            end
            return nil
        end)
        if ok and result then
            synsaveinstance = result
            print("[Delta] SSI încărcat de la: " .. url)
            break
        else
            print("[Delta] Eșuat la: " .. url .. " -> " .. tostring(result))
        end
    end
end

-- Metoda 3: require (unele executoare suportă asta)
if not synsaveinstance then
    pcall(function()
        synsaveinstance = require(14898888382) -- ID-ul SSI pe Roblox dacă e publicat
    end)
    if synsaveinstance then
        print("[Delta] SSI încărcat prin require!")
    end
end

if not synsaveinstance then
    warn("============================================")
    warn("[Delta] NU S-A PUTUT ÎNCĂRCA NICIO METODĂ DE SALVARE!")
    warn("")
    warn("Executor-ul tău nu suportă:")
    if not hasLoadstring then warn("  - loadstring (LIPSĂ)") end
    if not hasHttpGet then warn("  - HttpGet (LIPSĂ)") end
    warn("")
    warn("Verifică dacă Delta are saveinstance built-in.")
    warn("Încearcă în consolă: print(saveinstance)")
    warn("Sau încearcă: print(type(syn))")
    warn("============================================")

    pcall(function()
        writefile("Delta_Diagnostic.txt",
            "loadstring: " .. tostring(hasLoadstring) .. "\n" ..
            "HttpGet: " .. tostring(hasHttpGet) .. "\n" ..
            "saveinstance global: " .. tostring(saveinstance) .. "\n" ..
            "syn: " .. tostring(syn) .. "\n"
        )
    end)
    return
end

-- ===================== CACHE + SALVARE =====================
local teren = Workspace:FindFirstChildOfClass("Terrain")
local terenSuportat = false

if teren then
    teren.Archivable = true
    local ok = pcall(function()
        local r = Region3.new(Vector3.new(0,0,0), Vector3.new(4,4,4)):ExpandToGrid(4)
        teren:ReadVoxels(r, 4)
    end)
    terenSuportat = ok
    print("[Delta] ReadVoxels: " .. tostring(ok))
end

local CacheFolder = Instance.new("Folder")
CacheFolder.Name = "Delta_Cache"
CacheFolder.Parent = Lighting

local processed = {}
local cached = 0

local function cacheInst(inst)
    if inst:IsA("Terrain") then return end
    if not inst:IsA("BasePart") and not inst:IsA("Model") then return end
    if inst:IsDescendantOf(Players) then return end
    if inst:IsDescendantOf(CacheFolder) then return end

    local id = inst:GetDebugId()
    if processed[id] then return end
    processed[id] = true

    task.spawn(function()
        local ok, c = pcall(function() return inst:Clone() end)
        if ok and c then
            c.Archivable = true
            if c:IsA("BasePart") then c.Anchored = true
            else for _, d in ipairs(c:GetDescendants()) do
                if d:IsA("BasePart") then d.Anchored = true; d.Archivable = true end
            end end
            c.Parent = CacheFolder
            cached = cached + 1
        end
    end)
end

for _, v in ipairs(Workspace:GetDescendants()) do cacheInst(v) end
local listener = Workspace.DescendantAdded:Connect(cacheInst)
print("[Delta] Cache: " .. tostring(cached) .. " obiecte")

_G.SalveazaHartaFinala = function()
    print("[Delta] Salvare...")
    if listener then listener:Disconnect() end
    CacheFolder.Parent = Workspace

    if teren then teren.Archivable = true end

    local ok, err = pcall(function()
        synsaveinstance({
            Mode = "optimized",
            SaveTerrain = terenSuportat,
            IgnoreTerrain = not terenSuportat,
            IsPlace = true,
            Decompile = false,
            DecompileIgnore = {"CorePackages", "CoreGui"},
            FileName = "Harta_Salvata",
            Object = game,
            ShowStatus = true,
        })
    end)

    if ok then
        print("[Delta] SALVARE REUȘITĂ!")
    else
        warn("[Delta] Eroare: " .. tostring(err))
        if terenSuportat then
            print("[Delta] Retry fără teren...")
            local s2 = pcall(function()
                synsaveinstance({
                    Mode = "optimized", SaveTerrain = false, IgnoreTerrain = true,
                    IsPlace = true, Decompile = false, FileName = "Harta_Fara_Teren",
                    Object = game, ShowStatus = true,
                })
            end)
            print(s2 and "[Delta] Backup OK!" or "[Delta] Backup eșuat.")
        end
    end

    pcall(function() CacheFolder:Destroy() end)
end

print("[Delta] GATA! Cheamă _G.SalveazaHartaFinala()")
if not terenSuportat then
    warn("[Delta] Terenul NU va fi salvat (ReadVoxels lipsă).")
end
