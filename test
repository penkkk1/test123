local function getTowerTopPosition()
    local towerEnd = workspace:FindFirstChild("TowerEnd")
    if towerEnd and towerEnd:IsA("BasePart") then
        return towerEnd.Position + Vector3.new(0, 5, 0)
    end
    -- Fallback din ObbyConfig (confirmat: Origin=95,0,75 Stage=6 H=30)
    local origin = ObbyConfig.Origin
    local topY = origin.Y + (ObbyConfig.StageCount * ObbyConfig.StageHeight) + 10
    return Vector3.new(origin.X, topY, origin.Z)
end

local function getTowerBasePosition()
    return ObbyConfig.Origin + ObbyConfig.BaseSpawnOffset
end

local function teleportTo(pos)
