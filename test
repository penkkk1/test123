        Lighting.Technology = Enum.Technology.Compatibility  -- cel mai usor
        -- Sterge post-processing effects
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("BlurEffect") or child:IsA("SunRaysEffect") or
               child:IsA("BloomEffect") or child:IsA("ColorCorrectionEffect") or
               child:IsA("DepthOfFieldEffect") or child:IsA("Atmosphere") then
                child:Destroy()
            end
        end
    end)

    -- 2. Sterge TOATE particulele din workspace
    pcall(function()
        for _, desc in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or
                   desc:IsA("Beam") or desc:IsA("Smoke") or
                   desc:IsA("Fire") or desc:IsA("Sparkles") or
                   desc:IsA("PointLight") or desc:IsA("SpotLight") or
                   desc:IsA("SurfaceLight") then
                    desc.Enabled = false
                    -- sau desc:Destroy() daca vrei mai agresiv
                end
            end)
        end
    end)

    -- 3. Reduce calitatea texturilor si meshurilor
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    pcall(function()
        sethiddenproperty(Lighting, "Technology", Enum.Technology.Compatibility)
    end)

    -- 4. Sterge decoratiuni din Lobby/Map
    pcall(function()
        local lobby = workspace:FindFirstChild("Lobby")
        if lobby then
            for _, desc in ipairs(lobby:GetDescendants()) do
                pcall(function()
                    if desc:IsA("Decal") or desc:IsA("Texture") or
                       desc:IsA("SurfaceAppearance") then
                        desc:Destroy()
                    end
                end)
            end
        end
    end)

    -- 5. Reduce draw distance pt parti indepartate
    pcall(function()
        for _, desc in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if desc:IsA("BasePart") then
                    desc.Material = Enum.Material.SmoothPlastic
                    desc.Reflectance = 0
                    desc.CastShadow = false
                end
            end)
        end
    end)

    -- 6. Terrain simplificat
    pcall(function()
        workspace.Terrain.WaterWaveSize = 0
        workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0
        workspace.Terrain.WaterTransparency = 0
    end)

    -- 7. Disable player character rendering pt altii
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                pcall(function()
                    for _, part in ipairs(p.Character:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("Decal") then
                            part.Transparency = 1
                        end
                        if part:IsA("ParticleEmitter") then
                            part.Enabled = false
                        end
                    end
                end)
            end
        end
    end)

    -- 8. Sterge efectele din PetModels vizibile
    pcall(function()
        local clientFollowers = workspace:FindFirstChild("ClientFollowers")
        if clientFollowers then
            for _, desc in ipairs(clientFollowers:GetDescendants()) do
                pcall(function()
                    if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or
                       desc:IsA("PointLight") or desc:IsA("Highlight") then
                        desc.Enabled = false
                    end
                end)
            end
        end
    end)

    -- 9. Garbage collect
    pcall(function()
        collectgarbage("collect")
    end)

    print("[FPS BOOST] Toate optimizarile aplicate!")
end

local function removeFpsBoost()
    -- Nu putem restaura tot, dar marcam ca dezactivat
