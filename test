-- =====================================================
--  PERFORMANCE MONITORING
-- =====================================================
local perfStats = {
    cps       = 0,
    fps       = 0,
    remoteSec = 0,
}
local clickCounter    = 0
local remoteCounter   = 0
local lastPerfUpdate  = tick()
local lastGC          = tick()

RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastPerfUpdate >= 1 then
        perfStats.cps = clickCounter
        perfStats.remoteSec = remoteCounter
        perfStats.fps = math.floor(1 / RunService.Heartbeat:Wait() + 0.5)
        clickCounter = 0
        remoteCounter = 0
        lastPerfUpdate = now
    end
    -- GC la fiecare 30s, nu in loop tight
    if now - lastGC >= 30 then
        lastGC = now
        pcall(collectgarbage, "collect")
    end
end)

-- Wrapper pt contorizare remote calls
local function safeFireServer(remote, ...)
    remoteCounter += 1
