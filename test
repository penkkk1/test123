--[[
  CLICK ENGINE — Un singur loop.
  In v4 aveai Heartbeat + RenderStepped + 3x while loop
  = minim 5 loop-uri care fiecare trimiteau ClicksPerFrame
  clickuri. La 50 clicks/frame * 60fps * 5 loop-uri
  = ~15000 FireServer/secunda. Asta era cauza lagului.

  Acum: un singur task.spawn cu timing precis.
  La 50 cps, trimite 50 fire-uri pe secunda = 50 total.
--]]
task.spawn(function()
    while ScreenGui.Parent do
        if STATE.AutoClick then
            local cps = STATE.ClicksPerSecond
            -- Batch: trimite in rafale de max 10, cu delay intre
            local batchSize = math.min(cps, 10)
            local batches = math.ceil(cps / batchSize)
            local delayBetween = 1 / batches

            for b = 1, batches do
                if not STATE.AutoClick or not ScreenGui.Parent then break end
                -- Fire batch
                pcall(function()
                    for i = 1, batchSize do
                        safeFireServer(ClickAction)
                    end
                end)
                clickCounter += batchSize
                task.wait(delayBetween)
            end
        else
            task.wait(0.1)
        end
    end
end)

