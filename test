-- [DELTA SYSTEM] Script cu URL-ul original + diagnostic
local logData = "=== [DELTA SYSTEM] JURNAL DE DEBUG ===\n"
local LogService = game:GetService("LogService")

local logConnection = LogService.MessageOut:Connect(function(message, messageType)
    logData = logData .. os.date("[%X] ") .. "[" .. tostring(messageType) .. "] " .. message .. "\n"
end)

local function adaugaLog(msg)
    print(msg)
    logData = logData .. os.date("[%X] ") .. "[Delta Custom] " .. msg .. "\n"
end

adaugaLog("Se inițializează scriptul...")

-- URL-ul tău original
local RepoURL = "https://raw.githubusercontent.com/luau/SynSaveInstance/main/"
local SSI = "saveinstance"
local fullURL = RepoURL .. SSI .. ".luau"

adaugaLog("URL folosit: " .. fullURL)

-- Pas 1: Descărcăm codul
local okGet, rawCode = pcall(function()
    return game:HttpGet(fullURL, true)
end)

if not okGet then
    adaugaLog("EROARE: HttpGet a eșuat: " .. tostring(rawCode))
    return
end

if not rawCode or #rawCode < 100 then
    adaugaLog("EROARE: Codul descărcat e gol sau prea scurt (" .. tostring(rawCode and #rawCode or 0) .. " caractere)")
    return
end

adaugaLog("Cod descărcat cu succes: " .. tostring(#rawCode) .. " caractere")

-- Pas 2: Compilăm cu loadstring
local okLoad, compiled = pcall(function()
    return loadstring(rawCode, SSI)
end)

if not okLoad then
    adaugaLog("EROARE: loadstring a eșuat la compilare: " .. tostring(compiled))
    return
end

if not compiled then
    adaugaLog("EROARE: loadstring a returnat nil — executor-ul NU poate compila SSI!")
    adaugaLog("Asta e o limitare a Delta. Încearcă un alt executor.")
    return
end

adaugaLog("loadstring OK, se execută...")

-- Pas 3: Executăm funcția compilată
local okExec, synsaveinstance = pcall(compiled)

if not okExec then
    adaugaLog("EROARE: Execuția SSI a eșuat: " .. tostring(synsaveinstance))
    return
end

if not synsaveinstance then
    adaugaLog("EROARE: SSI s-a executat dar a returnat nil!")
    return
end

adaugaLog("SSI încărcat cu succes!")

-- Restul scriptului
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local teren = Workspace:FindFirstChildOfClass("Terrain")
local terenSuportat = false

if teren then
    teren.Archivable = true
    local okRead, errRead = pcall(function()
        local region = Region3.new(Vector3.new(0, 0, 0), Vector3.new(4, 4, 4))
        region = region:ExpandToGrid(4)
        teren:ReadVoxels(region, 4)
    end)
    if okRead then
        terenSuportat = true
        adaugaLog("ReadVoxels FUNCȚIONEAZĂ — terenul VA fi salvat.")
    else
        adaugaLog("ReadVoxels NU merge: " .. tostring(errRead))
    end
end

local CacheFolder = Lighting:FindFirstChild("Delta_Map_Cache_Protected")
if not CacheFolder then
    CacheFolder = Instance.new("Folder")
    CacheFolder.Name = "Delta_Map_Cache_Protected"
    CacheFolder.Parent = Lighting
end

local processedUIDs = {}
local totalObjectsCached = 0

local function cacheInstance(inst)
    if inst:IsA("Terrain") then return end
    if not inst:IsA("BasePart") and not inst:IsA("Model") then return end
    if inst:IsDescendantOf(Players) then return end
    if inst:IsDescendantOf(CacheFolder) then return end

    local uid = inst:GetDebugId()
    if processedUIDs[uid] then return end
    processedUIDs[uid] = true

    task.spawn(function()
        local ok, clona = pcall(function() return inst:Clone() end)
        if ok and clona then
            clona.Archivable = true
            if clona:IsA("BasePart") then
                clona.Anchored = true
            else
                for _, desc in ipairs(clona:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        desc.Anchored = true
                        desc.Archivable = true
                    end
                end
            end
            clona.Parent = CacheFolder
            totalObjectsCached = totalObjectsCached + 1
        end
    end)
end

adaugaLog("SCANARE HARTĂ PORNITĂ...")
for _, v in ipairs(Workspace:GetDescendants()) do
    cacheInstance(v)
end
local streamListener = Workspace.DescendantAdded:Connect(cacheInstance)
adaugaLog("Scanare completă. Obiecte: " .. tostring(totalObjectsCached))

_G.SalveazaHartaFinala = function()
    adaugaLog("=== SALVARE ===")
    if streamListener then streamListener:Disconnect() end
    CacheFolder.Parent = Workspace

    local terenFinal = Workspace:FindFirstChildOfClass("Terrain")
    if terenFinal then terenFinal.Archivable = true end

    local Options = {
        Mode = "optimized",
        SaveTerrain = terenSuportat,
        IgnoreTerrain = not terenSuportat,
        IsPlace = true,
        Decompile = false,
        DecompileIgnore = {"CorePackages", "CoreGui"},
        FileName = "Harta_Teren_Salvata",
        Object = game,
        ShowStatus = true,
    }

    adaugaLog("SaveTerrain=" .. tostring(Options.SaveTerrain))

    local success, err = pcall(function() synsaveinstance(Options) end)

    if success then
        adaugaLog("SALVARE REUȘITĂ!")
    else
        adaugaLog("EROARE: " .. tostring(err))
        if terenSuportat then
            adaugaLog("Retry fără teren...")
            Options.SaveTerrain = false
            Options.IgnoreTerrain = true
            Options.FileName = "Harta_FARA_Teren"
            local s2, e2 = pcall(function() synsaveinstance(Options) end)
            adaugaLog(s2 and "Backup reușit!" or ("Backup eșuat: " .. tostring(e2)))
        end
    end

    pcall(function() CacheFolder:Destroy() end)
    table.clear(processedUIDs)
    logConnection:Disconnect()
    pcall(function() writefile("Delta_Log_Salvare.txt", logData) end)
    print("[Delta] Gata! Verifică Delta_Log_Salvare.txt")
end

print("[Delta] Setup OK. Cheamă _G.SalveazaHartaFinala() când ești gata.")
if not terenSuportat then
    warn("[Delta] ReadVoxels nu merge — terenul NU va fi salvat.")
end
