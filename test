-- WHILE-LOOP CLICK (3 threads, adaptive yield)
for threadIdx = 1, 3 do
    task.spawn(function()
        local c = 0
        while ScreenGui.Parent do
            if STATE.AutoClick and STATE.ClickMethod_WH then
                for i = 1, STATE.ClicksPerFrame do
                    pcall(function() ClickAction:FireServer() end)
                end
                c = c + 1
                local yieldEvery = math.max(3, math.floor(300 / math.max(STATE.ClicksPerFrame, 1)))
                if c % yieldEvery == 0 then
                    task.wait()
                    if c % (yieldEvery * 25) == 0 then
                        pcall(function() collectgarbage("collect") end)
                    end
                end
            else
                task.wait(0.1)
            end
        end
    end)
end

