--  TELEMETRY (lightweight)
-- =====================================================
local TELEMETRY = {
    clicksSent      = 0,
    remotesSent     = 0,
    rebirthsDone    = 0,
    rebirthsFailed  = 0,
    towerWins       = 0,
    fps             = 60,
    cps             = 0,
    lastRebirthTime = 0,
    rebirthsPerMin  = 0,
    addValueWorks   = nil,  -- nil = untested, true/false = result
}

local _clickBuf   = 0
local _remoteBuf  = 0
local _rebirthBuf = 0
local _lastTelemetry = tick()
local _startTime     = tick()
local _lastGC        = tick()

-- Single heartbeat for telemetry + GC (very lightweight)
RunService.Heartbeat:Connect(function(dt)
    local now = tick()

    -- Update telemetry every 1 second
    if now - _lastTelemetry >= 1 then
        TELEMETRY.cps = _clickBuf
        TELEMETRY.remotesSent = _remoteBuf
        TELEMETRY.fps = math.floor(1 / dt + 0.5)
        if now - _startTime > 60 then
            TELEMETRY.rebirthsPerMin = TELEMETRY.rebirthsDone / ((now - _startTime) / 60)
        end
        _clickBuf = 0
        _remoteBuf = 0
        _lastTelemetry = now
    end

    -- GC every 60 seconds (not in tight loops!)
    if now - _lastGC >= 60 then
        _lastGC = now
        task.defer(collectgarbage, "collect")
    end
end)

-- Wrappers
local function fire(remote, ...)
    _remoteBuf += 1
    remote:FireServer(...)
end

local function invoke(remote, ...)
    _remoteBuf += 1
    return remote:InvokeServer(...)
end

