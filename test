-- =====================================================
--  TOWER POSITION CALCULATOR
--  ObbyConfig: Origin = 95,0,75 | StageCount=6 | StageHeight=30
--  Top = Origin.Y + StageCount * StageHeight = 180
--  Mai incercam si: gasim TowerEnd part direct
-- =====================================================
local function getTowerTopPosition()
    -- Metoda 1: Gaseste TowerEnd part in workspace
    local towerEnd = workspace:FindFirstChild("TowerEnd", true)
    if towerEnd and towerEnd:IsA("BasePart") then
        return towerEnd.Position + Vector3.new(0, 5, 0)
    end

    -- Metoda 2: Calculeaza din ObbyConfig
    local origin = ObbyConfig.Origin or Vector3.new(95, 0, 75)
    local stageCount = ObbyConfig.StageCount or 6
    local stageHeight = ObbyConfig.StageHeight or 30
    local topY = origin.Y + (stageCount * stageHeight) + 10
    return Vector3.new(origin.X, topY, origin.Z)

    -- Metoda 3: fallback hardcodat
    -- return Vector3.new(95, 195, 75)
end

local function getTowerBasePosition()
    local origin = ObbyConfig.Origin or Vector3.new(95, 0, 75)
    local offset = ObbyConfig.BaseSpawnOffset or Vector3.new(0, 5, -42)
    return origin + offset
end

local function teleportTo(pos)
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = CFrame.new(pos)
    return true
end

local function tpToTowerTop()
    local pos = getTowerTopPosition()
    local ok = teleportTo(pos)
    if ok then
        -- Incearca sa trigger-uie si completion event-ul
        pcall(function() FinishRemote:FireServer() end)
        -- Unele jocuri au touchpart detection - trebuie sa stai acolo
    end
    return ok
end

local function tpToTowerBase()
    return teleportTo(getTowerBasePosition())
end

-- =====================================================
--  FPS BOOST ENGINE
-- =====================================================
local fpsBoostApplied = false

local function applyFpsBoost()
    if fpsBoostApplied then return end
    fpsBoostApplied = true

    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        -- Sterge post-processing
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("BlurEffect") or child:IsA("SunRaysEffect") or
               child:IsA("BloomEffect") or child:IsA("ColorCorrectionEffect") or
               child:IsA("DepthOfFieldEffect") or child:IsA("Atmosphere") then
                child:Destroy()
            end
        end
    end)

    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- Disable particles, trails, lights everywhere
    pcall(function()
        for _, desc in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or
                   desc:IsA("Beam") or desc:IsA("Smoke") or
                   desc:IsA("Fire") or desc:IsA("Sparkles") then
                    desc.Enabled = false
                end
                if desc:IsA("PointLight") or desc:IsA("SpotLight") or
                   desc:IsA("SurfaceLight") then
                    desc.Enabled = false
                end
                if desc:IsA("BasePart") then
                    desc.Material = Enum.Material.SmoothPlastic
                    desc.CastShadow = false
                end
            end)
        end
    end)

    -- Terrain simplificat
    pcall(function()
        workspace.Terrain.WaterWaveSize = 0
        workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0
        workspace.Terrain.WaterTransparency = 0
    end)

    -- Alti playeri invizibili
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                for _, part in ipairs(p.Character:GetDescendants()) do
                    pcall(function()
                        if part:IsA("BasePart") or part:IsA("Decal") then
                            part.Transparency = 1
                        end
                    end)
                end
            end
        end
    end)

    pcall(function() collectgarbage("collect") end)
    print("[FPS BOOST] ON")
end

local function removeFpsBoost()
    fpsBoostApplied = false
    pcall(function()
        Lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    end)
    print("[FPS BOOST] OFF (rejoin pt restore complet)")
end

