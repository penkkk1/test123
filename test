-- Ascundem anumite erori native ale Roblox-ului din consola Delta pentru a nu fi distras
local CoreGui = game:GetService("CoreGui")
local Params = {
    RepoURL = "https://raw.githubusercontent.com/luau/SynSaveInstance/main/",
    SSI = "saveinstance",
}

-- Încărcăm librăria
local synsaveinstance = loadstring(game:HttpGet(Params.RepoURL .. Params.SSI .. ".luau", true), Params.SSI)()

local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local CacheFolder = Lighting:FindFirstChild("Delta_Map_Cache_Protected")
if not CacheFolder then
    CacheFolder = Instance.new("Folder")
    CacheFolder.Name = "Delta_Map_Cache_Protected"
    CacheFolder.Parent = Lighting
end

local processedUIDs = {}
local totalObjectsCached = 0
local activeThreads = 0

-- O funcție de clonare protejată extrem de robustă
local function cacheInstance(inst)
    if not inst:IsA("BasePart") and not inst:IsA("Model") then return end
    if inst:IsA("Terrain") then return end
    if inst:IsDescendantOf(Players) then return end
    if inst:IsDescendantOf(CacheFolder) then return end
    
    local uid = inst:GetDebugId()
    
    if not processedUIDs[uid] then
        processedUIDs[uid] = true
        activeThreads = activeThreads + 1
        
        task.spawn(function()
            local success, clona = pcall(function()
                local c = inst:Clone()
                if c then
                    c.Archivable = true
                    if c:IsA("BasePart") then
                        c.Anchored = true
                    else
                        for _, desc in ipairs(c:GetDescendants()) do
                            if desc:IsA("BasePart") then
                                desc.Anchored = true
                                desc.Archivable = true
                            end
                        end
                    end
                end
                return c
            end)
            
            if success and clona then
                clona.Parent = CacheFolder
                totalObjectsCached = totalObjectsCached + 1
            end
            
            activeThreads = activeThreads - 1
        end)
    end
end

print("\n\n-----------------------------------------")
print("[Delta System] V4 - SCANARE BLINDATĂ PORNITĂ")
print("-----------------------------------------\n")

for _, v in ipairs(Workspace:GetDescendants()) do
    cacheInstance(v)
end

local streamListener = Workspace.DescendantAdded:Connect(cacheInstance)

local notifyRoutine = task.spawn(function()
    while true do
        task.wait(5)
        if totalObjectsCached > 0 then
            print("[Delta Tracker] Obiecte arhivate: " .. tostring(totalObjectsCached))
        end
    end
end)

_G.SalveazaHartaFinala = function()
    print("[Delta System] INIȚIALIZARE SALVARE... Așteaptă.")
    
    if streamListener then streamListener:Disconnect() end
    if notifyRoutine then task.cancel(notifyRoutine) end
    
    while activeThreads > 0 do
        RunService.RenderStepped:Wait()
    end
    
    CacheFolder.Parent = Workspace 
    
    local Options = {
        Mode = "optimized",           
        SaveTrained = true,           
        Decompile = false,            
        DecompileIgnore = {"CorePackages", "CoreGui"},
        FileName = "Harta_O_Singura_Bucata",
        Object = Workspace            
    }
    
    local success, err = pcall(function()
        synsaveinstance(Options)
    end)
    
    if success then
        print("\n[Delta System] ✅ EXPORT FINALIZAT CU SUCCES! Caută 'Harta_O_Singura_Bucata' în fișierele Delta.\n")
    else
        warn("\n[Delta System] ❌ EROARE: " .. tostring(err) .. "\n")
    end
    
    CacheFolder:Destroy()
    table.clear(processedUIDs)
end
