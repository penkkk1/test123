-- METHOD 3: While-loop (fastest possible, adaptive yield)
-- Mai inteligent: yield mai des cand clicks/frame e mare
task.spawn(function()
    local counter = 0
    while ScreenGui.Parent do
        if STATE.AutoClick and STATE.ClickMethod_WH then
            for i = 1, STATE.ClicksPerFrame do
                pcall(function() ClickAction:FireServer() end)
            end
            counter = counter + 1
            -- Adaptive yield: cu cat mai multe clicks, yield mai des
            local yieldEvery = math.max(5, math.floor(500 / math.max(STATE.ClicksPerFrame, 1)))
            if counter % yieldEvery == 0 then
                task.wait()
                -- Garbage collect periodic la load mare
                if counter % (yieldEvery * 20) == 0 then
                    pcall(function() collectgarbage("collect") end)
                end
            end
        else
            task.wait(0.1)
        end
    end
end)

