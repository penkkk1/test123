    for n, btn in pairs(tabBtns) do
        local act = (n == name)
        TweenService:Create(btn, TweenInfo.new(0.1), {
            BackgroundColor3 = act and T.togOn or T.btnOff
        }):Play()
        btn.TextColor3 = act and T.bright or T.muted
