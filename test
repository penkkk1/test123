- ============================================================
-- [DELTA SYSTEM] Script fixat pentru salvarea hărții + teren
-- ============================================================

local logData = "=== [DELTA SYSTEM] JURNAL DE DEBUG ===\n"
local LogService = game:GetService("LogService")

local logConnection = LogService.MessageOut:Connect(function(message, messageType)
    logData = logData .. os.date("[%X] ") .. "[" .. tostring(messageType) .. "] " .. message .. "\n"
end)

local function adaugaLog(msg)
    print(msg)
    logData = logData .. os.date("[%X] ") .. "[Delta Custom] " .. msg .. "\n"
end

adaugaLog("Se inițializează scriptul...")

-- ============================================================
-- 1. Încărcăm librăria SynSaveInstance
-- ============================================================
local Params = {
    URLs = {
        "https://raw.githubusercontent.com/luau/SynSaveInstance/main/saveinstance.luau",
        "https://raw.githubusercontent.com/luau/UniversalSynSaveInstance/main/saveinstance.luau",
    }
}

local synsaveinstance = nil

for _, url in ipairs(Params.URLs) do
    local ok, result = pcall(function()
        return loadstring(game:HttpGet(url, true), "SSI")()
    end)
    if ok and result then
        synsaveinstance = result
        adaugaLog("Librăria SSI încărcată cu succes de la: " .. url)
        break
    else
        adaugaLog("Nu s-a putut încărca de la: " .. url .. " | Eroare: " .. tostring(result))
    end
end

if not synsaveinstance then
    adaugaLog("EROARE CRITICĂ: Nu s-a putut încărca librăria SynSaveInstance din nicio sursă!")
    logConnection:Disconnect()
    pcall(function() writefile("Delta_Log_Erori.txt", logData) end)
    return
end

-- ============================================================
-- 2. Verificăm suportul pentru teren
-- ============================================================
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local teren = Workspace:FindFirstChildOfClass("Terrain")
local terenSuportat = false

if teren then
    teren.Archivable = true
    adaugaLog("Terrain găsit în Workspace.")

    local okRead, errRead = pcall(function()
        local region = Region3.new(Vector3.new(0, 0, 0), Vector3.new(4, 4, 4))
        region = region:ExpandToGrid(4)
        teren:ReadVoxels(region, 4)
    end)

    if okRead then
        terenSuportat = true
        adaugaLog("ReadVoxels FUNCȚIONEAZĂ — terenul VA fi salvat.")
    else
        adaugaLog("ReadVoxels NU funcționează pe acest executor: " .. tostring(errRead))
        adaugaLog("Terenul NU va fi salvat. Executorul tău nu suportă această funcție.")
    end
else
    adaugaLog("AVERTISMENT: Terrain nu a fost găsit în Workspace.")
end

-- ============================================================
-- 3. Cache obiecte din Workspace (streaming)
-- ============================================================
local CacheFolder = Lighting:FindFirstChild("Delta_Map_Cache_Protected")
if not CacheFolder then
    CacheFolder = Instance.new("Folder")
    CacheFolder.Name = "Delta_Map_Cache_Protected"
    CacheFolder.Parent = Lighting
end

local processedUIDs = {}
local totalObjectsCached = 0

local function cacheInstance(inst)
    if inst:IsA("Terrain") then return end
    if not inst:IsA("BasePart") and not inst:IsA("Model") then return end
    if inst:IsDescendantOf(Players) then return end
    if inst:IsDescendantOf(CacheFolder) then return end

    local uid = inst:GetDebugId()
    if processedUIDs[uid] then return end
    processedUIDs[uid] = true

    task.spawn(function()
        local ok, clona = pcall(function() return inst:Clone() end)
        if ok and clona then
            clona.Archivable = true
            if clona:IsA("BasePart") then
                clona.Anchored = true
            else
                for _, desc in ipairs(clona:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        desc.Anchored = true
                        desc.Archivable = true
                    end
                end
            end
            clona.Parent = CacheFolder
            totalObjectsCached = totalObjectsCached + 1
        end
    end)
end

adaugaLog("SCANARE HARTĂ PORNITĂ...")

for _, v in ipairs(Workspace:GetDescendants()) do
    cacheInstance(v)
end

local streamListener = Workspace.DescendantAdded:Connect(cacheInstance)

adaugaLog("Scanare inițială completă. Obiecte cached: " .. tostring(totalObjectsCached))

-- ============================================================
-- 4. Funcția de salvare finală
-- ============================================================
_G.SalveazaHartaFinala = function()
    adaugaLog("=== INIȚIALIZARE SALVARE ===")

    if streamListener then
        streamListener:Disconnect()
        streamListener = nil
    end

    CacheFolder.Parent = Workspace

    local terenFinal = Workspace:FindFirstChildOfClass("Terrain")
    if terenFinal then
        terenFinal.Archivable = true
        adaugaLog("Terrain pregătit pentru salvare. Archivable = true")
    end

    local Options = {
        Mode = "optimized",
        SaveTerrain = terenSuportat,
        IgnoreTerrain = not terenSuportat,
        IsPlace = true,
        Decompile = false,
        DecompileIgnore = {"CorePackages", "CoreGui"},
        FileName = "Harta_Teren_Salvata",
        Object = game,
        ShowStatus = true,
    }

    adaugaLog("Opțiuni salvare:")
    adaugaLog("  SaveTerrain = " .. tostring(Options.SaveTerrain))
    adaugaLog("  IgnoreTerrain = " .. tostring(Options.IgnoreTerrain))
    adaugaLog("  Obiecte cached: " .. tostring(totalObjectsCached))
    adaugaLog("Se apelează synsaveinstance()...")

    local success, err = pcall(function()
        synsaveinstance(Options)
    end)

    if success then
        adaugaLog("SALVARE FINALIZATĂ CU SUCCES!")
    else
        adaugaLog("EROARE LA SALVARE: " .. tostring(err))

        -- Retry automat fără teren dacă a picat
        if terenSuportat then
            adaugaLog("Se reîncearcă FĂRĂ teren...")
            Options.SaveTerrain = false
            Options.IgnoreTerrain = true
            Options.FileName = "Harta_FARA_Teren_Backup"

            local s2, e2 = pcall(function()
                synsaveinstance(Options)
            end)

            if s2 then
                adaugaLog("Salvare BACKUP (fără teren) reușită!")
            else
                adaugaLog("EROARE și la backup: " .. tostring(e2))
            end
        end
    end

    pcall(function() CacheFolder:Destroy() end)
    table.clear(processedUIDs)

    logConnection:Disconnect()
    pcall(function()
        writefile("Delta_Log_Salvare.txt", logData)
    end)

    print("\n[Delta System] Gata! Verifică fișierul salvat și 'Delta_Log_Salvare.txt'.\n")
end

print("[Delta System] Setup complet. Cheamă _G.SalveazaHartaFinala() când ești gata.")
if not terenSuportat then
    warn("[Delta System] ATENȚIE: Executor-ul tău NU suportă ReadVoxels. Terenul nu va fi salvat.")
    warn("[Delta System] Pentru teren, ai nevoie de un executor pe PC (Synapse, Wave, Fluxus).")
end
