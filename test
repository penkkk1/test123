    t.BackgroundTransparency = 1
    t.Text = "CLICK SPEED (per frame)"
    t.TextColor3 = C.text
    t.Font = Enum.Font.GothamSemibold
    t.TextSize = 11
    t.TextXAlignment = Enum.TextXAlignment.Left
    t.Parent = panel

    -- Preset buttons
    local presets = {10, 50, 100, 250, 500, 1000}
