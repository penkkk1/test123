end

-- =====================================================
--  FPS BOOST (imbunatatit)
-- =====================================================
local fpsBoostApplied = false

local function applyFpsBoost()
    if fpsBoostApplied then return end
    fpsBoostApplied = true

    -- Lighting
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("PostEffect") or child:IsA("Atmosphere") or
               child:IsA("Sky") then
                child:Destroy()
            end
        end
    end)

    -- Rendering quality
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- Batch disable particles/lights/shadows pe tot workspace
    pcall(function()
        for _, desc in ipairs(workspace:GetDescendants()) do
            local ok, _ = pcall(function()
                if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or
                   desc:IsA("Beam") or desc:IsA("Smoke") or
                   desc:IsA("Fire") or desc:IsA("Sparkles") then
                    desc.Enabled = false
                elseif desc:IsA("PointLight") or desc:IsA("SpotLight") or
                       desc:IsA("SurfaceLight") then
                    desc.Enabled = false
                elseif desc:IsA("Decal") or desc:IsA("Texture") then
                    desc.Transparency = 1
                elseif desc:IsA("BasePart") then
                    desc.Material = Enum.Material.SmoothPlastic
                    desc.CastShadow = false
                end
            end)
        end
    end)

    -- Terrain
    pcall(function()
        local t = workspace.Terrain
        t.WaterWaveSize = 0
        t.WaterWaveSpeed = 0
        t.WaterReflectance = 0
        t.WaterTransparency = 0
        t.Decoration = false
    end)

    -- Alti playeri invizibili
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                for _, part in ipairs(p.Character:GetDescendants()) do
                    pcall(function()
                        if part:IsA("BasePart") or part:IsA("Decal") or
                           part:IsA("MeshPart") then
                            part.Transparency = 1
                        end
                    end)
                end
            end
        end
    end)

    print("[FPS BOOST] ON")
end

local function removeFpsBoost()
    fpsBoostApplied = false
    pcall(function()
        Lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    end)
    print("[FPS BOOST] OFF (rejoin pt restore complet)")
end

