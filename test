        b.TextColor3 = (STATE.ClicksPerFrame == val) and C.textBright or C.textMuted
        b.Font = Enum.Font.GothamBold
        b.TextSize = 12
        b.Parent = panel
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 5)
        presetBtns[i] = b
    end

    -- Custom input row
    local customLbl = Instance.new("TextLabel")
