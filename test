local function diff(before, after)
    local changes = {}
    for k, v in pairs(before) do
        if after[k] ~= v then
            table.insert(changes, k .. ": " .. tostring(v) .. " -> " .. tostring(after[k]))
        end
    end
    return changes
end

local function report(testName, before, after)
    local d = diff(before, after)
    if #d > 0 then
        print(">>> [HIT!] " .. testName .. " CHANGED SOMETHING:")
        for _, c in ipairs(d) do
            print("      " .. c)
        end
    else
        print("    [miss] " .. testName .. " — no change")
    end
end

