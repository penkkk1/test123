-- Inițializare sistem de Log-uri custom
local logData = "=== [DELTA SYSTEM] JURNAL DE DEBUG PENTRU SALVAREA TERENULUI ===\n"
local LogService = game:GetService("LogService")

-- Capturăm absolut toate mesajele și erorile ascunse din consolă
local logConnection = LogService.MessageOut:Connect(function(message, messageType)
    logData = logData .. os.date("[%X] ") .. "[" .. tostring(messageType) .. "] " .. message .. "\n"
end)

local function adaugaLog(msg)
    print(msg)
    logData = logData .. os.date("[%X] ") .. "[Delta Custom] " .. msg .. "\n"
end

adaugaLog("Se inițializează scriptul și se descarcă librăria...")

local CoreGui = game:GetService("CoreGui")
local Params = {
    RepoURL = "https://raw.githubusercontent.com/luau/SynSaveInstance/main/",
    SSI = "saveinstance",
}

-- Încărcăm librăria
local succesLib, synsaveinstance = pcall(function()
    return loadstring(game:HttpGet(Params.RepoURL .. Params.SSI .. ".luau", true), Params.SSI)()
end)

if not succesLib then
    adaugaLog("EROARE CRITICĂ: Nu s-a putut încărca librăria SynSaveInstance!")
end

local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local CacheFolder = Lighting:FindFirstChild("Delta_Map_Cache_Protected")
if not CacheFolder then
    CacheFolder = Instance.new("Folder")
    CacheFolder.Name = "Delta_Map_Cache_Protected"
    CacheFolder.Parent = Lighting
end

local processedUIDs = {}
local totalObjectsCached = 0

local function cacheInstance(inst)
    if not inst:IsA("BasePart") and not inst:IsA("Model") then return end
    if inst:IsA("Terrain") then return end 
    if inst:IsDescendantOf(Players) then return end
    if inst:IsDescendantOf(CacheFolder) then return end
    
    local uid = inst:GetDebugId()
    
    if not processedUIDs[uid] then
        processedUIDs[uid] = true
        
        task.spawn(function()
            pcall(function()
                local clona = inst:Clone()
                if clona then
                    clona.Archivable = true
                    if clona:IsA("BasePart") then
                        clona.Anchored = true
                    else
                        for _, desc in ipairs(clona:GetDescendants()) do
                            if desc:IsA("BasePart") then
                                desc.Anchored = true
                                desc.Archivable = true
                            end
                        end
                    end
                    clona.Parent = CacheFolder
                    totalObjectsCached = totalObjectsCached + 1
                end
            end)
        end)
    end
end

adaugaLog("SCANARE HARTĂ + TEREN PORNITĂ")

for _, v in ipairs(Workspace:GetDescendants()) do
    cacheInstance(v)
end

local streamListener = Workspace.DescendantAdded:Connect(cacheInstance)

-- Comanda de final
_G.SalveazaHartaFinala = function()
    adaugaLog("INIȚIALIZARE SALVARE JOC COMPLET... Se pregătește terenul.")
    
    if streamListener then streamListener:Disconnect() end
    
    -- Verificăm dacă terenul există și poate fi citit
    local teren = Workspace:FindFirstChildOfClass("Terrain")
    if teren then
        adaugaLog("Terenul nativ a fost detectat în Workspace. Se încearcă forțarea salvării lui.")
        teren.Archivable = true
    else
        adaugaLog("AVERTISMENT: Terenul (Workspace.Terrain) nu a fost găsit!")
    end
    
    CacheFolder.Parent = Workspace 
    
    local Options = {
        Mode = "optimized",           
        SaveTerrain = true,           
        IgnoreTerrain = false,
        IsPlace = true,               
        Decompile = false,            
        DecompileIgnore = {"CorePackages", "CoreGui"},
        FileName = "Harta_Teren_Test",
        Object = game,
        
        -- SETĂRI NOI DE DEBUG
        ShowStatus = true,
        __DEBUG_MODE = true -- Forțează librăria să printeze orice eroare legată de teren
    }
    
    adaugaLog("Se apelează funcția nativă de salvare. Jocul se va bloca...")
    
    local success, err = pcall(function()
        synsaveinstance(Options)
    end)
    
    if success then
        adaugaLog("EXPORT FINALIZAT CU SUCCES! Extensia ar trebui să fie .rbxlx")
    else
        adaugaLog("EROARE LA SALVARE BAZĂ: " .. tostring(err))
    end
    
    CacheFolder:Destroy()
    table.clear(processedUIDs)
    
    -- SALVĂM FIȘIERUL DE LOG-URI PE TELEFON
    logConnection:Disconnect()
    pcall(function()
        writefile("Delta_Log_Erori_Teren.txt", logData)
    end)
    
    print("\n[Delta System] Salvarea s-a încheiat. Verifică fișierul 'Delta_Log_Erori_Teren.txt' pentru a vedea de ce pică terenul!\n")
end

print("[Delta System] Setup finalizat cu sistem de log-uri. Cheamă _G.SalveazaHartaFinala() când ești gata.")
