local toggleButtons = {}

local function createSection(title, layoutOrder)
    local sec = Instance.new("TextLabel")
    sec.Size = UDim2.new(1, 0, 0, 24)
    sec.BackgroundTransparency = 1
    sec.Text = string.upper(title)
    sec.TextColor3 = C.textMuted
