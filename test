    customBox.PlaceholderColor3 = C.toggleOff
    customBox.Font = Enum.Font.GothamBold
    customBox.TextSize = 13
    customBox.ClearTextOnFocus = false
    customBox.Parent = panel
    Instance.new("UICorner", customBox).CornerRadius = UDim.new(0, 5)
    local boxStroke = Instance.new("UIStroke", customBox)
    boxStroke.Color = C.border
    boxStroke.Thickness = 1

    local applyBtn = Instance.new("TextButton")
    applyBtn.Size = UDim2.new(0, 60, 0, 26)
    applyBtn.Position = UDim2.new(0, 158, 0, 58)
    applyBtn.BackgroundColor3 = C.toggleOn
    applyBtn.BorderSizePixel = 0
    applyBtn.Text = "APPLY"
    applyBtn.TextColor3 = C.textBright
    applyBtn.Font = Enum.Font.GothamBold
    applyBtn.TextSize = 11
    applyBtn.Parent = panel
    Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 5)

    -- Current display
    local currentLbl = Instance.new("TextLabel")
    currentLbl.Name = "CurrentSpeed"
    currentLbl.Size = UDim2.new(0, 80, 0, 20)
    currentLbl.Position = UDim2.new(1, -88, 0, 62)
    currentLbl.BackgroundTransparency = 1
    currentLbl.Text = STATE.ClicksPerFrame .. "/frame"
    currentLbl.TextColor3 = C.green
    currentLbl.Font = Enum.Font.GothamBold
    currentLbl.TextSize = 12
    currentLbl.TextXAlignment = Enum.TextXAlignment.Right
    currentLbl.Parent = panel

    -- Warn label
    local warnLbl = Instance.new("TextLabel")
    warnLbl.Size = UDim2.new(1, -12, 0, 14)
    warnLbl.Position = UDim2.new(0, 6, 1, -16)
    warnLbl.BackgroundTransparency = 1
    warnLbl.Text = "> 500 poate lag-ui! 1000+ = risc de crash"
    warnLbl.TextColor3 = C.red
    warnLbl.Font = Enum.Font.Gotham
    warnLbl.TextSize = 9
    warnLbl.TextXAlignment = Enum.TextXAlignment.Left
    warnLbl.Parent = panel

    local function setSpeed(val)
        val = math.clamp(val, 1, 10000)
        STATE.ClicksPerFrame = val
        customBox.Text = tostring(val)
        currentLbl.Text = val .. "/frame"
        for i, b in ipairs(presetBtns) do
            local isActive = (presets[i] == val)
            TweenService:Create(b, TweenInfo.new(0.1), {
                BackgroundColor3 = isActive and C.btnActive or C.btnInactive
            }):Play()
            b.TextColor3 = isActive and C.textBright or C.textMuted
        end
    end

    for i, b in ipairs(presetBtns) do
        b.MouseButton1Click:Connect(function()
            setSpeed(presets[i])
        end)
    end

    applyBtn.MouseButton1Click:Connect(function()
        local n = tonumber(customBox.Text)
        if n then
            setSpeed(math.floor(n))
        end
    end)

    customBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local n = tonumber(customBox.Text)
            if n then setSpeed(math.floor(n)) end
        end
    end)
end

