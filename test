-- CLICK ENGINE (single loop, adaptive)
task.spawn(function()
    while SG.Parent do
        if STATE.AutoClick then
            local cps = STATE.ClicksPerSecond
            local batchSize = math.min(cps, 10)
            local batches = math.ceil(cps / batchSize)
            local delay = 1 / batches

            for b = 1, batches do
                if not STATE.AutoClick or not SG.Parent then break end
                pcall(function()
                    for i = 1, batchSize do
                        fire(ClickAction)
                    end
                end)
                _clickBuf += batchSize
                task.wait(delay)
            end
        else
            task.wait(0.1)
        end
    end
end)

-- ADDVALUE PUMP (tests if it works, then spams)
task.spawn(function()
    while SG.Parent do
        if STATE.AddValuePump or STATE.RebirthTurbo then
            -- Capture clicks before
            local before = stats.Clicks.Value
            pcall(fire, AddValue, "Clicks", 999999999)
            task.wait(0.3)
            local after = stats.Clicks.Value

            if after > before + 1000 then
                -- AddValue works!
                TELEMETRY.addValueWorks = true
                -- Continue pumping
                while (STATE.AddValuePump or STATE.RebirthTurbo) and SG.Parent do
                    pcall(fire, AddValue, "Clicks", 999999999)
                    task.wait(0.05)
                end
            else
                -- AddValue blocked — try alternative args
                pcall(fire, AddValue, 999999999)
                task.wait(0.3)
                local after2 = stats.Clicks.Value
                if after2 > before + 1000 then
                    TELEMETRY.addValueWorks = true
                    while (STATE.AddValuePump or STATE.RebirthTurbo) and SG.Parent do
                        pcall(fire, AddValue, 999999999)
                        task.wait(0.05)
                    end
                else
                    TELEMETRY.addValueWorks = false
                    -- Wait and retry later (maybe server changes)
                    task.wait(10)
                end
            end
        else
            task.wait(0.2)
        end
    end
end)

-- REBIRTH TURBO ENGINE
--[[
  Strategy:
  1. If AddValue works: pump clicks → rebirth → repeat (fastest)
  2. If AddValue blocked: auto click at max speed → rebirth when ready
  3. Track success rate. If 5 fails in a row, slow down.
  4. RequestSkipRebirth might bypass the normal cost entirely
     (the name "Skip" suggests it might use a different currency
     or just be a fast-track). We try it regardless.
--]]
task.spawn(function()
    local consecutiveFails = 0
    local rebirthDelay = 0.5

    while SG.Parent do
        if STATE.RebirthTurbo or STATE.AutoRebirth then
            local beforeRb = stats.RebirthCount.Value

            local ok, result = pcall(invoke, RequestSkipRebirth)

            local afterRb = stats.RebirthCount.Value
            if afterRb > beforeRb then
                -- Success!
                TELEMETRY.rebirthsDone += 1
                TELEMETRY.lastRebirthTime = tick()
                consecutiveFails = 0
                rebirthDelay = 0.3  -- go fast
            else
                consecutiveFails += 1
                -- Adaptive backoff
                if consecutiveFails >= 10 then
                    rebirthDelay = 3
                elseif consecutiveFails >= 5 then
                    rebirthDelay = 1.5
                else
                    rebirthDelay = 0.5
                end
            end

            task.wait(rebirthDelay)
        else
            task.wait(0.2)
        end
    end
end)

